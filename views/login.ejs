<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>" data-theme="<%= typeof theme !== 'undefined' ? theme : 'dark' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf" content="<%= csrf %>">
  <title><%= t('login') %> · <%= appName %></title>
  <% if (lang === 'fa') { %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css">
  <% } %>
  <link rel="stylesheet" href="/public/css/style.css?v=<%= typeof assetVer !== 'undefined' ? assetVer : '1' %>">
  <style>
    .login-wrapper {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 20px;
      background: var(--bg);
      background-image: var(--bg-grad);
      background-attachment: fixed;
    }
  </style>
</head>
<body style="margin:0">
  <span id="i18n"
    data-copied="<%= t('copied') %>" data-loading="<%= t('loading') %>" data-error="<%= t('error') %>"
    data-copy="<%= t('copy') %>"></span>

  <div class="login-wrapper">
    <div class="card login-card">
      <div class="brand">
        <%= appName.split(' ')[0] %><span class="dot">.</span>
      </div>
      <div class="tag"><%= t('login_subtitle') || appName %></div>

      <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="flash <%= flash.type %>">
          <%= flash.message %>
        </div>
      <% } %>

      <form method="post" action="/login">
        <input type="hidden" name="_csrf" value="<%= csrf %>">

        <div class="form-group">
          <label for="username"><%= t('username') %></label>
          <input
            id="username"
            type="text"
            name="username"
            autocomplete="username"
            autofocus
            required
            placeholder="<%= t('username') %>"
          >
        </div>

        <div class="form-group">
          <label for="password"><%= t('password') %></label>
          <input
            id="password"
            type="password"
            name="password"
            autocomplete="current-password"
            required
            placeholder="<%= t('password') %>"
          >
        </div>

        <button class="btn" style="width:100%; margin-top:20px" type="submit">
          <%= t('sign_in') %>
        </button>
      </form>
    </div>

    <div style="position: fixed; top: 20px; right: 20px; display: flex; gap: 8px;">
      <button class="icon-btn" type="button" id="themeBtn" onclick="toggleTheme()" title="dark / light" aria-label="theme">
        <%= (typeof theme !== 'undefined' ? theme : 'dark') === 'dark' ? '☀️' : '🌙' %>
      </button>
      <a class="lang-toggle" href="/lang/<%= lang === 'fa' ? 'en' : 'fa' %>">
        <%= t('switch_lang') %>
      </a>
    </div>
  </div>

  <script src="/public/js/app.js?v=<%= typeof assetVer !== 'undefined' ? assetVer : '1' %>"></script>
</body>
</html>
