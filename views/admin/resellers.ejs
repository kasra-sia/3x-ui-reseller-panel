<%- include('../partials/head', { title: t('resellers_title'), active: 'resellers' }) %>

<div class="page-head">
  <h1>⚇ <%= t('resellers_title') %></h1>
  <div class="spacer"></div>
  <button class="btn" onclick="openModal('newResellerModal')">
    + <%= t('new_reseller') %>
  </button>
</div>

<div class="card">
  <% if (!resellers.length) { %>
    <div class="empty-state">
      <div class="icon">👥</div>
      <div class="title"><%= t('no_resellers') %></div>
      <div class="description"><%= t('no_resellers_desc') || t('create_first_reseller') %></div>
      <button class="btn" onclick="openModal('newResellerModal')">
        <%= t('create_reseller') || t('new_reseller') %>
      </button>
    </div>
  <% } else { %>
    <div class="flex-between" style="margin-bottom: 16px;">
      <div class="muted" style="font-size: 0.9rem;">
        <%= resellers.length %> <%= t('resellers') %>
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t('col_username') %></th>
            <th><%= t('col_status') %></th>
            <th><%= t('col_clients') %></th>
            <th><%= t('col_created') %></th>
            <th style="text-align: center;"><%= t('col_actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% resellers.forEach(function(r){ %>
            <tr>
              <td>
                <strong><%= r.username %></strong>
              </td>
              <td>
                <span class="badge <%= r.enabled ? 'green' : 'muted' %>">
                  <%= r.enabled ? '✓ ' + t('enabled') : '✕ ' + t('disabled') %>
                </span>
              </td>
              <td>
                <strong><%= r.client_count %></strong>
              </td>
              <td class="muted nowrap">
                <%= fmt.formatDate(r.created_at) %>
              </td>
              <td class="actions" style="text-align: center;">
                <div class="btn-group gap-sm" style="justify-content: center;">
                  <a
                    class="btn sm ghost"
                    href="/admin/resellers/<%= r.id %>/assignments"
                    title="<%= t('assignments') %>"
                  >
                    <%= t('assignments') %>
                  </a>
                  <a
                    class="btn sm ghost"
                    href="/admin/resellers/<%= r.id %>/pricing"
                    title="<%= t('nav_pricing') %>"
                  >
                    <%= t('nav_pricing') %>
                  </a>
                  <button
                    class="btn sm ghost"
                    onclick="openResellerEdit(<%= r.id %>, '<%= r.username.replace(/'/g,"\\'") %>', <%= r.enabled %>)"
                    title="<%= t('edit') %>"
                  >
                    <%= t('edit') %>
                  </button>
                  <form
                    method="post"
                    action="/admin/resellers/<%= r.id %>/delete"
                    style="margin:0; display: inline;"
                    data-confirm="<%= t('confirm_delete_reseller') %>"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrf %>">
                    <button class="btn sm danger" type="submit">
                      <%= t('delete') %>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- New Reseller Modal -->
<div class="modal-back" id="newResellerModal">
  <div class="modal">
    <div class="modal-head">
      <h2>➕ <%= t('new_reseller') %></h2>
      <button class="close-x" onclick="closeModal('newResellerModal')" type="button">×</button>
    </div>

    <form method="post" action="/admin/resellers">
      <input type="hidden" name="_csrf" value="<%= csrf %>">

      <div class="modal-body">
        <div class="form-group">
          <label for="newUsername"><%= t('reseller_username') %></label>
          <input
            id="newUsername"
            type="text"
            name="username"
            required
            placeholder="<%= t('username') %>"
            autocomplete="off"
          >
        </div>

        <div class="form-group">
          <label for="newPassword"><%= t('reseller_password') %></label>
          <input
            id="newPassword"
            type="password"
            name="password"
            required
            placeholder="••••••••"
            autocomplete="new-password"
          >
        </div>

        <div class="form-group">
          <label class="checkbox">
            <input type="checkbox" name="enabled" checked>
            <%= t('reseller_enabled') %>
          </label>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn ghost" type="button" onclick="closeModal('newResellerModal')">
          <%= t('cancel') %>
        </button>
        <button class="btn" type="submit">
          <%= t('create') %>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Reseller Modal -->
<div class="modal-back" id="editResellerModal">
  <div class="modal">
    <div class="modal-head">
      <h2 id="editResellerTitle">✏️ <%= t('edit') %></h2>
      <button class="close-x" onclick="closeModal('editResellerModal')" type="button">×</button>
    </div>

    <form method="post" id="editResellerForm">
      <input type="hidden" name="_csrf" value="<%= csrf %>">

      <div class="modal-body">
        <div class="form-group">
          <label class="checkbox">
            <input type="checkbox" name="enabled" id="editResellerEnabled">
            <%= t('reseller_enabled') %>
          </label>
        </div>

        <div class="form-group">
          <label for="editPassword"><%= t('change_password') %></label>
          <input
            id="editPassword"
            type="password"
            name="password"
            placeholder="••••••••"
            autocomplete="new-password"
          >
          <div class="hint">
            <%= t('reseller_password_hint') || t('leave_blank_to_keep_current') %>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn ghost" type="button" onclick="closeModal('editResellerModal')">
          <%= t('cancel') %>
        </button>
        <button class="btn" type="submit">
          <%= t('save') %>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function openResellerEdit(id, username, enabled) {
    var f = document.getElementById('editResellerForm');
    f.action = '/admin/resellers/' + id + '/update';
    document.getElementById('editResellerTitle').textContent = username;
    document.getElementById('editResellerEnabled').checked = !!enabled;
    openModal('editResellerModal');
  }
</script>

<%- include('../partials/foot') %>
