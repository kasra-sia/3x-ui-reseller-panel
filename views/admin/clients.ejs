<%- include('../partials/head', { title: t('clients_title'), active: 'clients' }) %>

<div class="page-head">
  <h1>☰ <%= t('clients_title') %></h1>
  <div class="spacer"></div>
  <small class="muted"><%= clients.length %> <%= t('total') %></small>
</div>

<% if (panelErrors && panelErrors.length) { %>
  <div class="flash error">
    ⚠️ <%= t('err_panel', { msg: panelErrors.join(' · ') }) %>
  </div>
<% } %>

<!-- Filters -->
<div class="card">
  <h3 style="margin-top: 0;">🔍 <%= t('filters') || 'Filters' %></h3>
  <form method="get" action="/admin/clients" class="grid cols-2">
    <div class="form-group">
      <label for="filterOwner"><%= t('filter_owner') %></label>
      <select id="filterOwner" name="owner" onchange="this.form.submit()">
        <option value="all" <%= filters.owner==='all'?'selected':'' %>>👥 <%= t('all_owners') %></option>
        <option value="none" <%= filters.owner==='none'?'selected':'' %>>—  <%= t('no_owner') %></option>
        <% resellers.forEach(function(r){ %>
          <option value="<%= r.id %>" <%= String(filters.owner)===String(r.id)?'selected':'' %>>⚇ <%= r.username %></option>
        <% }); %>
      </select>
    </div>

    <% if (inbounds && inbounds.length) { %>
    <div class="form-group">
      <label for="filterInbound"><%= t('filter_inbound') %></label>
      <select id="filterInbound" name="inbound" onchange="this.form.submit()">
        <option value="all" <%= filters.inbound==='all'?'selected':'' %>>🌐 <%= t('all_inbounds') %></option>
        <% inbounds.forEach(function(ib){ %>
          <option value="<%= ib.id %>" <%= String(filters.inbound)===String(ib.id)?'selected':'' %>>
            <%= ib.remark %> (#<%= ib.id %>)
          </option>
        <% }); %>
      </select>
    </div>
    <% } %>

    <div class="form-group" style="grid-column: span 2;">
      <label for="searchQuery"><%= t('search') %></label>
      <div style="display: flex; gap: 8px;">
        <input
          id="searchQuery"
          type="text"
          name="q"
          value="<%= filters.q %>"
          placeholder="<%= t('search_email') %>"
        >
        <button class="btn" type="submit">🔎 <%= t('search') %></button>
      </div>
    </div>
  </form>

  <div class="hint" style="margin-top: 12px;">
    📊 <%= t('showing_count', { n: clients.length }) %>
  </div>
</div>

<!-- Clients Table -->
<div class="card">
  <% if (!clients.length) { %>
    <div class="empty-state">
      <div class="icon">📋</div>
      <div class="title"><%= t('no_clients') %></div>
      <div class="description"><%= t('no_clients_desc') || t('no_matching_clients') %></div>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th><%= t('col_client') %></th>
            <th><%= t('col_owner') %></th>
            <th><%= t('col_inbound2') %></th>
            <th><%= t('col_usage') %></th>
            <th><%= t('col_expiry') %></th>
            <th style="text-align: center;"><%= t('col_actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% clients.forEach(function(c){
               var pct = fmt.usagePercent(c.used, c.total);
               var color = fmt.usageColor(pct);
               var dleft = fmt.daysLeft(c.live_expiry);
          %>
            <tr>
              <td>
                <strong><%= c.email %></strong>
                <% if (!c.live_enable) { %>
                  <span class="badge red">✕ <%= t('disabled') %></span>
                <% } %>
              </td>
              <td class="muted"><%= c.owner %></td>
              <td class="muted nowrap">
                <code><%= c.server_name %> #<%= c.inbound_id %></code>
              </td>
              <td>
                <div class="usage">
                  <div class="bar <%= color === fmt.usageColor(100) ? 'full' : color === fmt.usageColor(75) ? 'warning' : '' %>">
                    <span style="width:<%= Math.min(100,pct) %>%;"></span>
                  </div>
                  <div class="lbl">
                    <% if (c.total > 0) { %>
                      <%= fmt.formatBytes(c.used) %> / <%= fmt.formatBytes(c.total) %> (<%= pct %>%)
                    <% } else { %>
                      <%= fmt.formatBytes(c.used) %> · ∞ <%= t('unlimited') %>
                    <% } %>
                  </div>
                </div>
              </td>
              <td class="nowrap text-center">
                <% if (dleft === null) { %>
                  <span class="badge muted">⏱️ <%= t('no_expiry') %></span>
                <% } else if (dleft < 0) { %>
                  <span class="badge red">❌ <%= t('expired') %></span>
                <% } else { %>
                  <span class="badge <%= dleft <= 3 ? 'yellow' : 'green' %>">
                    📅 <%= t('days_left_n', { n: dleft }) %>
                  </span>
                <% } %>
              </td>
              <td class="actions" style="text-align: center;">
                <div class="btn-group gap-sm" style="justify-content: center;">
                  <button
                    class="btn sm success"
                    onclick="getLinks('/admin/clients/<%= c.server_id %>/links?email=<%= encodeURIComponent(c.email) %>&subId=<%= encodeURIComponent(c.sub_id || '') %>')"
                    title="<%= t('get_link') %>"
                  >
                    🔗 <%= t('link') || 'Link' %>
                  </button>
                  <button
                    class="btn sm ghost"
                    onclick="openRenewAdmin(<%= c.server_id %>, '<%= c.email.replace(/'/g,"\\'") %>', <%= c.reseller_id %>)"
                    title="<%= t('renew') %>"
                  >
                    🔄 <%= t('renew') %>
                  </button>
                  <form
                    method="post"
                    action="/admin/clients/<%= c.server_id %>/delete"
                    style="margin:0; display: inline;"
                    data-confirm="<%= t('confirm_delete_client') %>"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrf %>">
                    <input type="hidden" name="email" value="<%= c.email %>">
                    <input type="hidden" name="reseller_id" value="<%= c.reseller_id %>">
                    <button class="btn sm danger" type="submit">
                      🗑️ <%= t('delete') %>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Renew Client Modal -->
<div class="modal-back" id="renewModal">
  <div class="modal">
    <div class="modal-head">
      <h2 id="renewTitle" data-tpl="🔄 <%= t('renew_title', { email: '{email}' }) %>">
        🔄 <%= t('renew_client') %>
      </h2>
      <button class="close-x" onclick="closeModal('renewModal')" type="button">×</button>
    </div>

    <form method="post" id="renewForm">
      <input type="hidden" name="_csrf" value="<%= csrf %>">
      <input type="hidden" name="email" id="renewEmail" value="">
      <input type="hidden" name="reseller_id" id="renewReseller" value="">

      <div class="modal-body">
        <p class="hint">
          <%= t('renew_hint') %>
        </p>

        <div class="form-group">
          <label for="renewPlan"><%= t('select_plan') %></label>
          <select id="renewPlan" name="plan_id" required></select>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn ghost" type="button" onclick="closeModal('renewModal')">
          <%= t('cancel') %>
        </button>
        <button class="btn success" type="submit">
          🔄 <%= t('renew') %>
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Links/Subscription Modal -->
<div class="modal-back" id="linkModal">
  <div class="modal">
    <div class="modal-head">
      <h2>🔗 <%= t('link_title') %></h2>
      <button class="close-x" onclick="closeModal('linkModal')" type="button">×</button>
    </div>
    <div id="linkBody" class="modal-body"></div>
  </div>
</div>

<script>
  var RESELLER_PLANS = <%- JSON.stringify(plansByReseller) %>;
  function openRenewAdmin(serverId, email, resellerId) {
    var form = document.getElementById('renewForm');
    form.action = '/admin/clients/' + serverId + '/renew';
    document.getElementById('renewEmail').value = email;
    document.getElementById('renewReseller').value = resellerId;
    var sel = document.getElementById('renewPlan');
    var plans = RESELLER_PLANS[resellerId] || [];
    sel.innerHTML = '';
    if (!plans.length) {
      var o = document.createElement('option'); o.value = ''; o.textContent = '—'; sel.appendChild(o);
    }
    plans.forEach(function (p) {
      var o = document.createElement('option'); o.value = p.id; o.textContent = p.label; sel.appendChild(o);
    });
    var title = document.getElementById('renewTitle');
    if (title) title.textContent = title.dataset.tpl.replace('{email}', email);
    openModal('renewModal');
  }
</script>

<%- include('../partials/foot') %>
