# ==========================================================================
# 3x-ui Reseller Panel — environment configuration
# Copy this file to ".env" and fill in the real values BY HAND on the server.
# NEVER commit your real .env to git (.env is already in .gitignore).
# ==========================================================================

# --- Public site -----------------------------------------------------------
# The public domain this panel is served on.
APP_DOMAIN=manage.keguard.top

# Internal port the Node app listens on.
# MUST NOT be 80, 443, or any port already in use (e.g. the 3x-ui panel's port).
# Pick a free high port. Default chosen for this project: 8443.
APP_PORT=8443

# --- TLS / serving ---------------------------------------------------------
# self  = Node terminates HTTPS itself using the certs below (default, no nginx needed)
# proxy = Node listens on plain HTTP and a reverse proxy in front handles TLS
TLS_MODE=self

# Directory that contains the TLS cert + key for APP_DOMAIN.
# The app auto-detects the filenames inside this folder (fullchain/cert + privkey/key).
TLS_CERT_DIR=./cert
# Optional explicit overrides if auto-detection picks the wrong files:
# TLS_CERT_FILE=./cert/fullchain.pem
# TLS_KEY_FILE=./cert/privkey.pem

# --- Default 3x-ui panel (optional seed) -----------------------------------
# These seed a first "Server" row on initial DB init. After that, the Admin
# manages servers from the web UI (you can add more panels there).
# Include the panel's custom port AND custom base path, exactly as in the panel.
PANEL_BASE_URL=https://edge1.viqora.top:6985/baghlava
# API token generated inside the 3x-ui panel (Panel Settings -> API). Sent as
# "Authorization: Bearer <token>". Leave blank to configure servers only via UI.
PANEL_API_TOKEN=
# Base URL of the panel's subscription server, used to build sub links:
#   sub link = {PANEL_SUB_BASE_URL}/{subId}
# Example: https://edge1.viqora.top:2096/sub   (no trailing slash)
PANEL_SUB_BASE_URL=

# Verify the panel's TLS certificate when this app calls it (server-to-server).
# Many 3x-ui panels use a self-signed cert on a custom port, so the default is
# false (do not verify). Set true only if your panel has a valid public cert.
PANEL_VERIFY_TLS=false

# --- Telegram admin notifications ------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- App session -----------------------------------------------------------
# Random long string used to sign session cookies. Generate one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# First-run Admin account (used only when the DB is initialized the first time).
# Change the password after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-run

# Default UI language: en (English) or fa (Persian, RTL)
DEFAULT_LANG=en
